# رشتہ v0.3 — typed edges
# 4 new primitive relations: استاد, سوتن, گواہ, جوڑ

# === استاد — ML training lineage ===
کردار ٹریننگ_ڈیٹا = 10000 حساس جانی
کردار ماڈل = ٹریننگ_ڈیٹا * 2

استاد ماڈل = ٹریننگ_ڈیٹا

پھوٹ ماڈل
استاد_چین ماڈل

# === سوتن — fallback parent (A/B / COALESCE) ===
کردار پرائمری = "primary endpoint"
کردار بیک_اپ = "backup endpoint"
کردار سروس = پرائمری + " v1"
سوتن سروس = بیک_اپ

شجرہ سروس

# === گواہ — read-only audit snapshot ===
کردار قیمت = 1000 جانی
گواہ آڈٹ_سنیپ = قیمت
پھوٹ آڈٹ_سنیپ

# === جوڑ — JOIN (creates سمدھی between sources) ===
کردار صارفین = 100 حساس
کردار آرڈرز = 50
جوڑ صارفین سے آرڈرز بنا فل_ٹیبل

پھوٹ فل_ٹیبل
شجرہ فل_ٹیبل
رساؤ فل_ٹیبل
