# ML feature leak detection
# کوئی بھی feature جو حساس ڈیٹا سے بنا ہو — auto-tag

کردار سی_این_آئی_سی = 4210112345678 حساس جانی
کردار عمر = 25
کردار شہر = "کراچی"

# apparently-safe derived feature — but lineage leaks PII
کردار یوزر_ہیش = سی_این_آئی_سی + عمر
کردار ماڈل_فیچر = یوزر_ہیش * 2

# another feature, completely separate
کردار موسم_اسکور = عمر + 10

پھوٹ ماڈل_فیچر
پھوٹ موسم_اسکور

رساؤ ماڈل_فیچر
رساؤ موسم_اسکور

شجرہ ماڈل_فیچر
