# Closures اور first-class functions
کام بنانے_والا(شروع) {
    سن گنتی = شروع
    کام اگلا() {
        گنتی = گنتی + 1
        واپس گنتی
    }
    واپس اگلا
}

سن کاؤنٹر = بنانے_والا(10)
بول کاؤنٹر()
بول کاؤنٹر()
بول کاؤنٹر()

# فہرستیں
سن کھانے = ["بریانی", "نہاری", "پائے", "حلیم"]
شامل(کھانے, "سیخ کباب")
بول "کل ڈشز:", لمبائی(کھانے)
ہرایک ڈش میں کھانے {
    بول "کھا لے:", ڈش
}
