# Closures اور first-class functions
کام بنانے_والا(شروع) {
    سن گنتی = شروع
    کام اگلا() {
        گنتی = گنتی + 1
        کلٹی گنتی
    }
    کلٹی اگلا
}

سن کاؤنٹر = بنانے_والا(10)
پھوٹ کاؤنٹر()
پھوٹ کاؤنٹر()
پھوٹ کاؤنٹر()

# فہرستیں
سن کھانے = ["بریانی", "نہاری", "پائے", "حلیم"]
ڈال(کھانے, "سیخ کباب")
پھوٹ "کل ڈشز:", لمبائی(کھانے)
ہرایک ڈش میں کھانے {
    پھوٹ "کھا لے:", ڈش
}
